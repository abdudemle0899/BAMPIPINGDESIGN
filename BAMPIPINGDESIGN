<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Abdu Demle Melaku | Piping Design Engineer & Team Leader | CRTEC</title>
<meta name="description" content="Abdu Demle Melaku - Mechanical Engineer specializing in petrochemical piping design with AVEVA PDMS, E3D, Paragon, and Navisworks. Team Leader at CRTEC with 17+ industrial projects.">
<link href="https://cdn.jsdelivr.net/npm/fontsource-inter@5.0.0/index.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/fontsource-rajdhani@5.0.0/index.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/fontsource-jetbrains-mono@5.0.0/index.css" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#050810;
  --bg-alt:#0a1020;
  --bg-elevated:#0f1629;
  --card:#111a2e;
  --card-hover:#162038;
  --cyan:#00e5ff;
  --cyan-soft:#4dd0e1;
  --cyan-dim:rgba(0,229,255,0.12);
  --cyan-glow:rgba(0,229,255,0.45);
  --amber:#ffb300;
  --amber-dim:rgba(255,179,0,0.12);
  --green:#00e676;
  --red:#ff5252;
  --purple:#b388ff;
  --text:#dfe6f0;
  --text-dim:#7d8ba3;
  --text-bright:#ffffff;
  --border:rgba(139,149,165,0.12);
  --border-light:rgba(139,149,165,0.25);
  --radius:14px;
  --radius-sm:10px;
  --radius-lg:20px;
  --shadow:0 20px 60px rgba(0,0,0,0.6);
  --shadow-lg:0 30px 80px rgba(0,0,0,0.8);
  --transition-fast:0.2s cubic-bezier(0.4,0,0.2,1);
  --transition:0.35s cubic-bezier(0.4,0,0.2,1);
  --transition-slow:0.6s cubic-bezier(0.4,0,0.2,1);
}
html{scroll-behavior:smooth}
body{
  font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;
  background:var(--bg);
  color:var(--text);
  line-height:1.65;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
}
h1,h2,h3,h4,h5,h6{
  font-family:'Rajdhani',sans-serif;
  font-weight:700;
  line-height:1.15;
  letter-spacing:-0.01em;
  color:var(--text-bright);
}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none}
img{max-width:100%;display:block}
.container{max-width:1380px;margin:0 auto;padding:0 32px}
.section{padding:120px 0;position:relative}
.section-label{
  display:inline-flex;
  align-items:center;
  gap:14px;
  font-family:'JetBrains Mono',monospace;
  font-size:0.78rem;
  color:var(--cyan);
  letter-spacing:3px;
  text-transform:uppercase;
  margin-bottom:20px;
  font-weight:500;
}
.section-label::before{
  content:'';
  width:50px;
  height:1px;
  background:linear-gradient(90deg,var(--cyan),transparent);
}
.section-title{
  font-size:clamp(2.4rem,5vw,3.6rem);
  color:var(--text-bright);
  margin-bottom:24px;
  letter-spacing:-0.02em;
}
.section-title span{color:var(--cyan)}
.section-subtitle{
  color:var(--text-dim);
  max-width:740px;
  font-size:1.1rem;
  line-height:1.75;
}

/* ==================== NAVIGATION ==================== */
.nav{
  position:fixed;
  top:0;left:0;right:0;
  z-index:1000;
  padding:24px 0;
  transition:all var(--transition);
}
.nav.scrolled{
  background:rgba(5,8,16,0.92);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  padding:14px 0;
  border-bottom:1px solid var(--border);
}
.nav-inner{
  display:flex;
  align-items:center;
  justify-content:space-between;
}
.nav-logo{
  font-family:'Rajdhani',sans-serif;
  font-weight:700;
  font-size:1.55rem;
  color:var(--text-bright);
  display:flex;
  align-items:center;
  gap:12px;
  letter-spacing:0.5px;
}
.nav-logo-mark{
  width:42px;
  height:42px;
  background:linear-gradient(135deg,var(--cyan),#0091ea);
  border-radius:11px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:1.15rem;
  color:var(--bg);
  font-weight:800;
  box-shadow:0 8px 20px rgba(0,229,255,0.3);
}
.nav-logo span{color:var(--cyan)}
.nav-links{display:flex;gap:4px;align-items:center}
.nav-links a{
  color:var(--text-dim);
  font-size:0.9rem;
  font-weight:500;
  padding:10px 18px;
  border-radius:var(--radius-sm);
  transition:all var(--transition-fast);
  position:relative;
}
.nav-links a:hover{
  color:var(--cyan);
  background:var(--cyan-dim);
}
.nav-cta{
  background:transparent!important;
  border:1px solid var(--cyan)!important;
  color:var(--cyan)!important;
  font-weight:600!important;
}
.nav-cta:hover{
  background:var(--cyan)!important;
  color:var(--bg)!important;
  transform:translateY(-2px);
}
.nav-toggle{
  display:none;
  background:none;
  border:none;
  color:var(--text-bright);
  font-size:1.7rem;
  cursor:pointer;
  padding:8px;
}

/* ==================== HERO ==================== */
.hero{
  position:relative;
  overflow:hidden;
  min-height:100vh;
  display:flex;
  align-items:center;
}
.hero-banner-wrap{
  position:absolute;
  inset:0;
  z-index:0;
}
.hero-banner{
  width:100%;
  height:100%;
  object-fit:cover;
  object-position:center;
  display:block;
}
.hero-overlay{
  position:absolute;
  inset:0;
  z-index:1;
  background:linear-gradient(135deg,rgba(5,8,16,0.94) 0%,rgba(5,8,16,0.78) 40%,rgba(5,8,16,0.88) 100%);
}
.hero-grid{
  position:absolute;
  inset:0;
  z-index:2;
  background-image:
    linear-gradient(rgba(0,229,255,0.05) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,229,255,0.05) 1px,transparent 1px);
  background-size:70px 70px;
  mask-image:radial-gradient(ellipse at center,black 30%,transparent 80%);
  -webkit-mask-image:radial-gradient(ellipse at center,black 30%,transparent 80%);
}
.hero-content{
  position:relative;
  z-index:3;
  display:grid;
  grid-template-columns:1fr 1.3fr;
  gap:80px;
  align-items:center;
  padding:150px 0 110px;
  width:100%;
}
.hero-img-wrap{
  position:relative;
  max-width:430px;
  margin:0 auto;
}
.hero-img{
  position:relative;
  border-radius:var(--radius);
  overflow:hidden;
  aspect-ratio:3/4;
  background:var(--card);
  box-shadow:0 30px 80px rgba(0,0,0,0.7);
}
.hero-img img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:transform var(--transition-slow);
}
.hero-img:hover img{transform:scale(1.05)}
.hero-img::before{
  content:'';
  position:absolute;
  inset:0;
  border:2px solid var(--cyan);
  border-radius:var(--radius);
  z-index:2;
  pointer-events:none;
}
.hero-img-accent{
  position:absolute;
  top:24px;
  left:24px;
  right:-24px;
  bottom:-24px;
  border:1px solid var(--cyan-dim);
  border-radius:var(--radius);
  z-index:-1;
}
.hero-badge{
  position:absolute;
  bottom:-20px;
  right:-20px;
  background:var(--card);
  border:1px solid var(--border-light);
  padding:14px 24px;
  border-radius:var(--radius-sm);
  z-index:3;
  display:flex;
  align-items:center;
  gap:12px;
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
}
.hero-badge-dot{
  width:10px;
  height:10px;
  background:var(--green);
  border-radius:50%;
  animation:pulse 2s infinite;
}
@keyframes pulse{
  0%,100%{box-shadow:0 0 0 0 rgba(0,230,118,0.6)}
  50%{box-shadow:0 0 0 10px rgba(0,230,118,0)}
}
.hero-badge-text{
  font-size:0.85rem;
  color:var(--text-bright);
  font-weight:600;
}
.hero-text .greeting{
  font-family:'JetBrains Mono',monospace;
  color:var(--cyan);
  font-size:1rem;
  margin-bottom:20px;
  letter-spacing:1.5px;
  font-weight:500;
}
.hero-text h1{
  font-size:clamp(3rem,7vw,5.2rem);
  color:var(--text-bright);
  margin-bottom:12px;
  letter-spacing:-0.03em;
  line-height:1.02;
}
.hero-text h1 span{
  display:block;
  color:var(--cyan);
  font-weight:600;
  font-size:0.48em;
  margin-top:10px;
  letter-spacing:0.5px;
}
.hero-text .tagline{
  font-size:1.18rem;
  color:var(--text-dim);
  margin:26px 0 38px;
  max-width:560px;
  line-height:1.75;
}
.hero-stats{
  display:flex;
  gap:22px;
  margin-bottom:38px;
  flex-wrap:wrap;
}
.hero-stat{
  padding:20px 24px;
  background:rgba(17,26,46,0.7);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  min-width:125px;
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
  transition:all var(--transition);
}
.hero-stat:hover{
  border-color:var(--cyan);
  transform:translateY(-4px);
  box-shadow:0 10px 30px rgba(0,229,255,0.15);
}
.hero-stat-num{
  font-family:'Rajdhani',sans-serif;
  font-size:2.3rem;
  font-weight:700;
  color:var(--cyan);
  line-height:1;
}
.hero-stat-label{
  font-size:0.76rem;
  color:var(--text-dim);
  margin-top:8px;
  text-transform:uppercase;
  letter-spacing:1.2px;
  font-weight:500;
}
.hero-actions{display:flex;gap:16px;flex-wrap:wrap}
.btn{
  display:inline-flex;
  align-items:center;
  gap:10px;
  padding:16px 32px;
  border-radius:var(--radius-sm);
  font-weight:600;
  font-size:0.95rem;
  transition:all var(--transition);
  cursor:pointer;
  border:none;
  font-family:inherit;
  letter-spacing:0.3px;
}
.btn-primary{
  background:var(--cyan);
  color:var(--bg);
}
.btn-primary:hover{
  background:#33ebff;
  transform:translateY(-3px);
  box-shadow:0 14px 34px var(--cyan-glow);
}
.btn-outline{
  background:transparent;
  color:var(--text-bright);
  border:1px solid var(--border-light);
}
.btn-outline:hover{
  border-color:var(--cyan);
  color:var(--cyan);
  transform:translateY(-3px);
}

/* ==================== ABOUT ==================== */
.about-grid{
  display:grid;
  grid-template-columns:1fr 1.3fr;
  gap:100px;
  align-items:center;
}
.about-img{
  border-radius:var(--radius);
  overflow:hidden;
  box-shadow:var(--shadow);
  position:relative;
  background:var(--card);
}
.about-img img{
  width:100%;
  height:auto;
  max-height:560px;
  object-fit:contain;
  display:block;
  background:var(--bg-alt);
}
.about-content h2{
  font-size:clamp(2.4rem,4vw,3.2rem);
  color:var(--text-bright);
  margin-bottom:24px;
}
.about-content h2 span{color:var(--cyan)}
.about-content p{
  color:var(--text-dim);
  margin-bottom:20px;
  font-size:1.05rem;
  line-height:1.8;
}
.about-info{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16px;
  margin-top:40px;
}
.about-info-item{
  display:flex;
  gap:16px;
  align-items:center;
  padding:16px;
  background:var(--card);
  border-radius:var(--radius-sm);
  border:1px solid var(--border);
  transition:all var(--transition);
}
.about-info-item:hover{
  border-color:var(--cyan);
  transform:translateX(4px);
}
.about-info-icon{
  width:42px;
  height:42px;
  min-width:42px;
  background:var(--cyan-dim);
  border-radius:var(--radius-sm);
  display:flex;
  align-items:center;
  justify-content:center;
  color:var(--cyan);
  font-size:1.15rem;
}
.about-info-label{
  font-size:0.72rem;
  color:var(--text-dim);
  text-transform:uppercase;
  letter-spacing:1.2px;
  margin-bottom:3px;
  font-weight:500;
}
.about-info-value{
  font-size:0.92rem;
  color:var(--text-bright);
  font-weight:600;
}

/* ==================== TIMELINE ==================== */
.experience{background:var(--bg-alt)}
.timeline{position:relative;max-width:940px;margin:0 auto}
.timeline::before{
  content:'';
  position:absolute;
  left:50%;
  top:0;
  bottom:0;
  width:2px;
  background:linear-gradient(to bottom,var(--cyan),transparent);
  transform:translateX(-50%);
}
.timeline-item{
  position:relative;
  margin-bottom:50px;
  width:50%;
  padding:0 46px;
}
.timeline-item:nth-child(odd){left:0;text-align:right}
.timeline-item:nth-child(even){left:50%}
.timeline-dot{
  position:absolute;
  top:24px;
  width:18px;
  height:18px;
  background:var(--cyan);
  border-radius:50%;
  border:3px solid var(--bg);
  box-shadow:0 0 0 5px var(--cyan-dim);
}
.timeline-item:nth-child(odd) .timeline-dot{right:-9px}
.timeline-item:nth-child(even) .timeline-dot{left:-9px}
.timeline-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:32px;
  transition:all var(--transition);
}
.timeline-card:hover{
  border-color:var(--cyan);
  transform:translateY(-5px);
  box-shadow:0 15px 40px rgba(0,229,255,0.15);
}
.timeline-date{
  font-family:'JetBrains Mono',monospace;
  color:var(--cyan);
  font-size:0.85rem;
  margin-bottom:12px;
  letter-spacing:1px;
  font-weight:500;
}
.timeline-card h3{
  font-size:1.35rem;
  color:var(--text-bright);
  margin-bottom:8px;
}
.timeline-card .company{
  color:var(--amber);
  font-weight:600;
  margin-bottom:16px;
  font-size:0.98rem;
}
.timeline-card ul{list-style:none}
.timeline-card li{
  color:var(--text-dim);
  font-size:0.92rem;
  margin-bottom:10px;
  padding-left:20px;
  position:relative;
  line-height:1.65;
}
.timeline-card li::before{
  content:'▸';
  position:absolute;
  left:0;
  color:var(--cyan);
}
.timeline-item:nth-child(odd) .timeline-card li{
  padding-left:0;
  padding-right:20px;
}
.timeline-item:nth-child(odd) .timeline-card li::before{
  left:auto;
  right:0;
}

/* ==================== EDUCATION ==================== */
.edu-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:46px;
  display:grid;
  grid-template-columns:auto 1fr auto;
  gap:38px;
  align-items:center;
  max-width:940px;
  margin:0 auto;
  transition:all var(--transition);
}
.edu-card:hover{border-color:var(--cyan)}
.edu-icon{
  width:90px;
  height:90px;
  background:linear-gradient(135deg,var(--cyan-dim),rgba(0,229,255,0.05));
  border-radius:var(--radius);
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:2.4rem;
}
.edu-info h3{
  font-size:1.6rem;
  color:var(--text-bright);
  margin-bottom:8px;
}
.edu-info .school{
  color:var(--cyan);
  font-weight:600;
  margin-bottom:12px;
  font-size:1.05rem;
}
.edu-info p{
  color:var(--text-dim);
  font-size:0.94rem;
  margin-bottom:6px;
  line-height:1.65;
}
.edu-award{
  background:var(--amber-dim);
  border:1px solid rgba(255,179,0,0.35);
  padding:20px 26px;
  border-radius:var(--radius-sm);
  text-align:center;
  min-width:170px;
}
.edu-award-label{
  font-size:0.7rem;
  color:var(--amber);
  text-transform:uppercase;
  letter-spacing:1.5px;
  margin-bottom:8px;
  font-family:'JetBrains Mono',monospace;
  font-weight:600;
}
.edu-award-value{
  font-size:1.9rem;
  font-family:'Rajdhani',sans-serif;
  font-weight:700;
  color:var(--amber);
  line-height:1;
}

/* ==================== SKILLS ==================== */
.skills{background:var(--bg-alt)}
.skills-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(330px,1fr));
  gap:28px;
}
.skill-category{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:36px;
  transition:all var(--transition);
}
.skill-category:hover{
  border-color:var(--cyan);
  transform:translateY(-6px);
  box-shadow:0 18px 45px rgba(0,229,255,0.12);
}
.skill-category-header{
  display:flex;
  align-items:center;
  gap:16px;
  margin-bottom:28px;
}
.skill-category-icon{
  width:50px;
  height:50px;
  background:var(--cyan-dim);
  border-radius:var(--radius-sm);
  display:flex;
  align-items:center;
  justify-content:center;
  color:var(--cyan);
  font-size:1.5rem;
}
.skill-category h3{
  font-size:1.3rem;
  color:var(--text-bright);
}
.skill-item{margin-bottom:20px}
.skill-header{
  display:flex;
  justify-content:space-between;
  margin-bottom:12px;
}
.skill-name{
  font-size:0.94rem;
  color:var(--text);
  font-weight:500;
}
.skill-level{
  font-family:'JetBrains Mono',monospace;
  font-size:0.84rem;
  color:var(--cyan);
  font-weight:600;
}
.skill-bar{
  height:7px;
  background:rgba(139,149,165,0.12);
  border-radius:4px;
  overflow:hidden;
}
.skill-fill{
  height:100%;
  background:linear-gradient(90deg,var(--cyan),#33ebff);
  border-radius:4px;
  width:0;
  transition:width 1.7s cubic-bezier(0.4,0,0.2,1);
}

/* ==================== LANGUAGES ==================== */
.lang-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(310px,1fr));
  gap:28px;
  max-width:940px;
  margin:75px auto 0;
}
.lang-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:32px;
  transition:all var(--transition);
}
.lang-card:hover{border-color:var(--cyan)}
.lang-card h4{
  font-size:1.25rem;
  color:var(--text-bright);
  margin-bottom:8px;
}
.lang-card .lang-type{
  font-size:0.82rem;
  color:var(--cyan);
  font-family:'JetBrains Mono',monospace;
  margin-bottom:22px;
  letter-spacing:1px;
  font-weight:500;
}
.lang-level{
  display:flex;
  align-items:center;
  gap:12px;
  margin-bottom:12px;
  font-size:0.88rem;
}
.lang-level-label{
  width:125px;
  color:var(--text-dim);
  font-size:0.85rem;
}
.lang-level-bar{
  flex:1;
  height:7px;
  background:rgba(139,149,165,0.12);
  border-radius:4px;
  overflow:hidden;
}
.lang-level-fill{
  height:100%;
  background:linear-gradient(90deg,var(--cyan),#33ebff);
  border-radius:4px;
}
.lang-level-val{
  width:34px;
  text-align:right;
  font-family:'JetBrains Mono',monospace;
  color:var(--cyan);
  font-size:0.84rem;
  font-weight:600;
}

/* ==================== PROJECTS ==================== */
.projects-filter{
  display:flex;
  gap:12px;
  flex-wrap:wrap;
  margin-bottom:55px;
  justify-content:center;
}
.filter-btn{
  padding:11px 22px;
  background:var(--card);
  border:1px solid var(--border);
  border-radius:100px;
  color:var(--text-dim);
  font-size:0.88rem;
  font-weight:500;
  cursor:pointer;
  transition:all var(--transition-fast);
  font-family:inherit;
}
.filter-btn:hover{
  border-color:var(--cyan);
  color:var(--cyan);
}
.filter-btn.active{
  background:var(--cyan);
  color:var(--bg);
  border-color:var(--cyan);
  font-weight:600;
}
.projects-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(380px,1fr));
  gap:30px;
}
.project-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
  transition:all var(--transition);
  position:relative;
  cursor:pointer;
}
