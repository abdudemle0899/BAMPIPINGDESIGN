  margin-bottom:10px;
  letter-spacing:-0.01em;
}
.modal-hero-client{
  color:var(--amber);
  font-size:1.05rem;
  font-weight:600;
}
.modal-body{padding:44px}
.modal-meta-grid{
  display:grid;
