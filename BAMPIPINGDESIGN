}

/* ==================== RECOMMENDATIONS ==================== */
.recommendations{background:var(--bg-alt)}
.rec-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(370px,1fr));
  gap:30px;
}
.rec-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:38px;
  position:relative;
  transition:all var(--transition);
}
.rec-card:hover{
  border-color:var(--cyan);
  transform:translateY(-6px);
  box-shadow:0 18px 45px rgba(0,229,255,0.12);
}
.rec-quote{
  font-size:3.8rem;
  color:var(--cyan);
  opacity:0.25;
  line-height:1;
  font-family:Georgia,serif;
  position:absolute;
  top:22px;
  right:30px;
}
.rec-text{
  color:var(--text);
  font-size:1rem;
  line-height:1.85;
  margin-bottom:30px;
  font-style:italic;
}
.rec-author{display:flex;gap:16px;align-items:center}
.rec-avatar{
  width:56px;
  height:56px;
  background:linear-gradient(135deg,var(--cyan),var(--purple));
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  color:var(--bg);
  font-weight:700;
  font-size:1.25rem;
}
.rec-author-info h4{
  font-size:1.08rem;
  color:var(--text-bright);
  margin-bottom:4px;
}
.rec-author-info p{
  font-size:0.87rem;
  color:var(--text-dim);
}
.rec-contact{
  font-size:0.82rem;
  color:var(--cyan);
  font-family:'JetBrains Mono',monospace;
  margin-top:6px;
}

/* ==================== CONTACT ==================== */
.contact{background:var(--bg-alt)}
.contact-grid{
  display:grid;
  grid-template-columns:1fr 1.3fr;
  gap:75px;
}
.contact-info{display:flex;flex-direction:column;gap:20px}
.contact-item{
  display:flex;
  gap:20px;
  align-items:flex-start;
  padding:24px;
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  transition:all var(--transition);
}
.contact-item:hover{
  border-color:var(--cyan);
  transform:translateX(6px);
}
.contact-icon{
  width:54px;
  height:54px;
  min-width:54px;
  background:var(--cyan-dim);
  border-radius:var(--radius-sm);
  display:flex;
  align-items:center;
  justify-content:center;
  color:var(--cyan);
  font-size:1.35rem;
}
.contact-item h4{
  font-size:0.78rem;
  color:var(--text-dim);
  text-transform:uppercase;
  letter-spacing:1.5px;
  margin-bottom:6px;
  font-weight:500;
}
.contact-item p{
  font-size:1rem;
  color:var(--text-bright);
  font-weight:500;
}
.contact-form{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:46px;
}
.form-group{margin-bottom:24px}
.form-group label{
  display:block;
  font-size:0.88rem;
  font-weight:600;
  color:var(--text-bright);
  margin-bottom:12px;
}
.form-group input,.form-group textarea{
  width:100%;
  padding:16px 20px;
  background:var(--bg);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  font-family:inherit;
  font-size:1rem;
  color:var(--text-bright);
  transition:all var(--transition-fast);
}
.form-group input:focus,.form-group textarea:focus{
  outline:none;
  border-color:var(--cyan);
  box-shadow:0 0 0 3px var(--cyan-dim);
}
.form-group textarea{resize:vertical;min-height:140px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:20px}

/* ==================== FOOTER ==================== */
.footer{
  background:var(--bg);
  border-top:1px solid var(--border);
  padding:75px 0 30px;
}
.footer-grid{
  display:grid;
  grid-template-columns:2fr 1fr 1fr;
  gap:55px;
  margin-bottom:55px;
}
.footer-brand h3{
  font-family:'Rajdhani',sans-serif;
  font-size:1.65rem;
  color:var(--text-bright);
  margin-bottom:16px;
}
.footer-brand h3 span{color:var(--cyan)}
.footer-brand p{
  color:var(--text-dim);
  font-size:0.94rem;
  max-width:360px;
  line-height:1.75;
}
.footer-col h4{
  color:var(--text-bright);
  font-size:1.08rem;
  margin-bottom:20px;
}
.footer-col ul{list-style:none}
.footer-col li{margin-bottom:13px}
.footer-col a{
  color:var(--text-dim);
  font-size:0.94rem;
  transition:color var(--transition-fast);
}
.footer-col a:hover{color:var(--cyan)}
.footer-social{display:flex;gap:14px;margin-top:22px}
.footer-social a{
  width:46px;
  height:46px;
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  display:flex;
  align-items:center;
  justify-content:center;
  color:var(--text-dim);
  transition:all var(--transition-fast);
  font-weight:700;
}
.footer-social a:hover{
  background:var(--cyan);
  color:var(--bg);
  border-color:var(--cyan);
  transform:translateY(-4px);
}
.footer-bottom{
  padding-top:30px;
  border-top:1px solid var(--border);
  text-align:center;
  font-size:0.88rem;
  color:var(--text-dim);
}

/* ==================== ANIMATIONS ==================== */
.fade-up{
  opacity:0;
  transform:translateY(40px);
  transition:all 0.9s cubic-bezier(0.4,0,0.2,1);
}
.fade-up.visible{opacity:1;transform:translateY(0)}

/* ==================== RESPONSIVE ==================== */
@media(max-width:1080px){
  .hero-content{grid-template-columns:1fr;gap:60px;padding:130px 0 90px}
  .hero-img-wrap{max-width:360px}
  .about-grid,.contact-grid{grid-template-columns:1fr;gap:60px}
  .timeline::before{left:22px}
  .timeline-item{width:100%;left:0!important;padding-left:58px;padding-right:0;text-align:left!important}
  .timeline-item:nth-child(odd) .timeline-card li{padding-left:20px;padding-right:0}
  .timeline-item:nth-child(odd) .timeline-card li::before{left:0;right:auto}
  .timeline-dot{left:13px!important;right:auto!important}
  .edu-card{grid-template-columns:1fr;text-align:center}
  .footer-grid{grid-template-columns:1fr}
  .projects-grid{grid-template-columns:repeat(auto-fill,minmax(320px,1fr))}
}
@media(max-width:768px){
  .nav-links{
    display:none;
    position:absolute;
    top:100%;
    left:0;
    right:0;
    background:var(--bg);
    flex-direction:column;
    padding:20px;
    border-bottom:1px solid var(--border);
    gap:4px;
  }
  .nav-links.open{display:flex}
  .nav-toggle{display:block}
  .section{padding:80px 0}
  .hero-content{padding:110px 0 70px}
  .hero-stats{gap:14px}
  .hero-stat{min-width:110px;padding:16px 18px}
  .hero-stat-num{font-size:1.9rem}
  .about-info,.form-row{grid-template-columns:1fr}
  .modal-body{padding:26px}
  .modal-hero{height:300px}
  .modal-hero-content{left:26px;right:26px;bottom:22px}
  .projects-grid{grid-template-columns:1fr}
  .modal-gallery-grid{grid-template-columns:1fr 1fr}
  .container{padding:0 22px}
  .modal-contribution{flex-direction:column;text-align:center}
}
@media(max-width:480px){
  .hero-text h1{font-size:2.5rem}
  .hero-img-wrap{max-width:290px}
  .modal-gallery-grid{grid-template-columns:1fr}
  .section-title{font-size:2rem}
}

